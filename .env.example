# Database
DATABASE_URL="postgresql://user:password@localhost:5432/sistema_mype?schema=public"

# JWT
JWT_SECRET=your-secret-key-here
JWT_REFRESH_SECRET=your-refresh-secret-key-here

# API
PORT=4000
BACKEND_URL=http://localhost:4000
RENIEC_TOKEN=your-apiperu-token-here

# Frontend URL for CORS (production)
# FRONTEND_URL=https://your-frontend-domain.up.railway.app

# Twilio WhatsApp Business API
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=your-bucket-name

# SUNAT
SUNAT_API_URL=https://api.sunat.gob.pe
QPSE_ACCESS_TOKEN=your-qpse-access-token-here
QPSE_USE_DEMO=false
QPSE_BASE_URL=https://cpe.qpse.pe
QPSE_AUTH_BASE_URL=https://cpanel.qpse.pe
QPSE_PANEL_BASE_URL=https://cpanel.qpse.pe
QPSE_DEMO_BASE_URL=https://demo-cpe.qpse.pe

# JAMBLE (opcional, para ajustar rutas si el reseller usa endpoints distintos)
JAMBLE_API_ISSUE_PATHS=/api/documents,/documents
JAMBLE_API_STATUS_PATH=/api/documents/{id}
JAMBLE_API_VOID_PATH=/api/documents/{id}/void
JAMBLE_API_SEND_PATHS=/api/documents/send,/documents/send,/api/documents/send/{id},/documents/send/{id}
JAMBLE_API_STATUS_PATHS=/api/documents/{id},/documents/{id},/api/documents/record/{id}
JAMBLE_API_LIST_PATHS=/api/documents/lists/{date_ini}/{date_end},/documents/lists/{date_ini}/{date_end}
# Recomendación: usar SOLO un método de autenticación por cliente:
# 1) Bearer token (billingApiToken) o 2) Basic auth (billingApiUser + billingApiPassword)
# Piso de correlativo por empresa y serie (opcional):
# Formato: empresaId:SERIE:CORRELATIVO,empresaId:SERIE:CORRELATIVO
# Ejemplo:
# JAMBLE_CORRELATIVO_FLOOR=43:B001:60,43:F001:16
JAMBLE_CORRELATIVO_FLOOR=
# Para JAMBLE, por defecto NO se fuerza /documents/send porque /documents ya confirma registro exitoso.
# Activar solo si el proveedor lo exige explícitamente.
JAMBLE_FORCE_DISPATCH=false

# SMTP (para envío de SIRE por correo)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-correo@gmail.com
SMTP_PASS=tu-contraseña-de-aplicacion
SMTP_FROM=tu-correo@gmail.com

# Sincronización Falconext Hotel (producto HOTEL)
HOTEL_BACKEND_SYNC_URL=http://localhost:5000/api/v1/autenticacion/sync-from-mype
HOTEL_BACKEND_SYNC_TOKEN=FALCONEXT_TOKEN_SY
