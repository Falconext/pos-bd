<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cotización</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: Arial, sans-serif;
            font-size: 11px;
            padding: 20px 24px;
            line-height: 1.4;
            color: #111;
        }

        /* ── HEADER ─────────────────────────────────────────────── */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 18px;
        }
        .logo-empresa {
            display: flex;
            align-items: flex-start;
            flex: 1;
        }
        .logo-empresa img {
            width: 90px;
            height: 90px;
            margin-right: 14px;
            object-fit: contain;
        }
        .empresa-info h1 {
            font-size: 20px;
            font-weight: bold;
            margin-bottom: 4px;
        }
        .empresa-info p {
            font-size: 10px;
            line-height: 1.7;
        }
        .documento {
            border: 2px solid #000;
            padding: 10px 18px;
            text-align: center;
            min-width: 170px;
        }
        .documento .ruc { font-size: 11px; margin-bottom: 4px; }
        .documento .tipo { font-size: 20px; font-weight: bold; margin: 4px 0; }
        .documento .numero { font-size: 12px; margin-top: 4px; }

        /* ── DATA BOXES ─────────────────────────────────────────── */
        .data-section {
            display: flex;
            gap: 14px;
            margin-bottom: 16px;
        }
        .data-col { flex: 1; }
        .data-col-title {
            font-weight: bold;
            font-size: 9.5px;
            color: #555;
            text-transform: uppercase;
            letter-spacing: 0.4px;
            margin-bottom: 4px;
            padding-bottom: 3px;
            border-bottom: 1px solid #ccc;
        }
        .data-box {
            border: 1.5px solid #000;
            border-radius: 6px;
            padding: 10px 12px;
        }
        .data-box table { width: 100%; border-collapse: collapse; }
        .data-box table td {
            font-size: 10px;
            padding: 2px 0;
            vertical-align: top;
        }
        .data-box table td:first-child {
            font-weight: bold;
            width: 90px;
            white-space: nowrap;
        }

        /* ── PRODUCTS TABLE ─────────────────────────────────────── */
        .productos-table {
            width: 100%;
            border: 1.5px solid #000;
            border-collapse: collapse;
            margin-bottom: 14px;
        }
        .productos-table thead {
            background-color: #e8e8e8;
            border-bottom: 1.5px solid #000;
        }
        .productos-table th {
            padding: 7px 5px;
            font-size: 10px;
            font-weight: bold;
            text-align: center;
            border-right: 1px solid #aaa;
        }
        .productos-table th:last-child { border-right: none; }
        .productos-table td {
            padding: 5px 5px;
            font-size: 10px;
            border-bottom: 1px solid #ddd;
            border-right: 1px solid #ddd;
        }
        .productos-table td:last-child { border-right: none; }
        .productos-table tbody tr:last-child td { border-bottom: none; }
        .col-n    { width: 5%;  text-align: center; }
        .col-cant { width: 8%;  text-align: center; }
        .col-um   { width: 9%;  text-align: center; }
        .col-img  { width: 9%;  text-align: center; }
        .col-img img { width: 34px; height: 34px; object-fit: cover; }
        .col-desc { text-align: left; }
        .col-moneda { width: 9%; text-align: center; }
        .col-pu   { width: 10%; text-align: right; }
        .col-tot  { width: 10%; text-align: right; }

        /* ── SON ────────────────────────────────────────────────── */
        .son-section {
            border: 1.5px solid #000;
            border-radius: 6px;
            padding: 9px 14px;
            margin-bottom: 14px;
            font-size: 12px;
            font-weight: bold;
            text-align: center;
        }

        /* ── FOOTER SECTION ─────────────────────────────────────── */
        .footer-section {
            display: flex;
            gap: 14px;
            margin-bottom: 16px;
        }
        .observaciones-box {
            flex: 1;
            border: 1.5px solid #000;
            border-radius: 6px;
            padding: 11px 12px;
        }
        .obs-title { font-weight: bold; font-size: 11px; margin-bottom: 5px; }
        .obs-text  { font-size: 10px; line-height: 1.5; }
        .bank-block { margin-top: 10px; font-size: 10px; line-height: 1.7; }
        .bank-block .bank-header { font-weight: bold; margin-bottom: 2px; }
        /* Tabla compacta de cuentas bancarias (al pie del documento) */
        .bank-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 14px;
            font-size: 10px;
        }
        .bank-table th, .bank-table td {
            border: 1px solid #000;
            padding: 5px 8px;
            text-align: center;
        }
        .bank-table th { font-weight: bold; background: #f2f2f2; }
        .bank-table .bank-td-name { font-weight: bold; }

        .totales-box {
            width: 240px;
            border: 1.5px solid #000;
            border-radius: 6px;
            padding: 11px 12px;
        }
        .totales-box .row {
            display: flex;
            justify-content: space-between;
            font-size: 10px;
            margin-bottom: 3px;
        }
        .totales-box .row.total-final {
            font-weight: bold;
            font-size: 12px;
            padding-top: 5px;
            border-top: 2px solid #000;
            margin-top: 4px;
        }

        /* ── GRACIAS ────────────────────────────────────────────── */
        .footer-thanks {
            text-align: center;
            margin-bottom: 12px;
        }
        .footer-thanks p {
            font-size: 10.5px;
            font-weight: bold;
            line-height: 1.6;
        }

        /* ── BOTTOM STRIP ───────────────────────────────────────── */
        .footer-bottom {
            border-top: 1px solid #bbb;
            padding-top: 7px;
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
        }
        .footer-bottom .usuario-label { font-size: 9px; color: #555; }
        .footer-bottom .marca-label {
            font-size: 9px;
            color: #555;
            font-style: italic;
            text-align: right;
        }
    </style>
</head>

<body>

    <!-- ── HEADER ─────────────────────────────────────────────────── -->
    <div class="header">
        <div class="logo-empresa">
            {{#if logo}}<img src="{{logo}}" alt="Logo" style="width: {{logoSize}}px; height: {{logoSize}}px;">{{/if}}
            <div class="empresa-info">
                <h1>{{nombreComercial}}</h1>
                <p>
                    <strong>{{direccion}}</strong><br>
                    {{rubro}}<br>
                    {{#unless (eq mostrarRazonSocial false)}}RAZON SOCIAL: {{razonSocial}}<br>{{/unless}}
                    CELULAR: {{celular}}<br>
                    {{#unless (eq mostrarEmail false)}}{{#if email}}EMAIL: {{email}}<br>{{/if}}{{/unless}}
                    {{#if paginaWeb}}WEB: {{paginaWeb}}{{/if}}
                </p>
            </div>
        </div>
        <div class="documento">
            <div class="ruc">RUC: {{ruc}}</div>
            <div class="tipo">COTIZACIÓN</div>
            <div class="numero">{{serie}}-{{correlativo}}</div>
        </div>
    </div>

    <!-- ── DATA BOXES ─────────────────────────────────────────────── -->
    <div class="data-section">
        <div class="data-col">
            <div class="data-col-title">Datos del Cliente</div>
            <div class="data-box">
                <table>
                    <tr><td>CLIENTE:</td><td>{{clienteNombre}}</td></tr>
                    <tr><td>RUC:</td><td>{{clienteNumDoc}}</td></tr>
                    <tr><td>EMAIL:</td><td>{{clienteEmail}}</td></tr>
                    <tr><td>TELF:</td><td>{{clienteTelefono}}</td></tr>
                    <tr><td>DIR:</td><td>{{clienteDireccion}}</td></tr>
                </table>
            </div>
        </div>
        <div class="data-col">
            <div class="data-col-title">Datos de la Cotización</div>
            <div class="data-box">
                <table>
                    <tr><td>FECHA EMISIÓN:</td><td>{{fecha}}</td></tr>
                    <tr><td>CONDICIÓN:</td><td>{{formaPago}}</td></tr>
                    <tr><td>VALIDEZ:</td><td>{{validez}}</td></tr>
                    <tr><td>MONEDA:</td><td>{{monedaNombre}}</td></tr>
                </table>
            </div>
        </div>
    </div>

    <!-- ── PRODUCTS TABLE ──────────────────────────────────────────── -->
    <table class="productos-table">
        <thead>
            <tr>
                <th class="col-n">N°</th>
                <th class="col-cant">CANT.</th>
                <th class="col-um">UNIDAD</th>
                {{#if includeProductImages}}<th class="col-img">IMAGEN</th>{{/if}}
                <th class="col-desc">DESCRIPCIÓN</th>
                <th class="col-moneda">MONEDA</th>
                <th class="col-pu">P.UNIT.</th>
                <th class="col-tot">TOTAL</th>
            </tr>
        </thead>
        <tbody>
            {{#each productos}}
            <tr>
                <td class="col-n">{{inc @index}}</td>
                <td class="col-cant">{{cantidad}}</td>
                <td class="col-um">{{unidadMedida}}</td>
                {{#if ../includeProductImages}}
                <td class="col-img">{{#if imagenUrl}}<img src="{{imagenUrl}}" alt="" />{{else}}-{{/if}}</td>
                {{/if}}
                <td class="col-desc">{{descripcion}}</td>
                <td class="col-moneda">{{../monedaSimbolo}}</td>
                <td class="col-pu">{{precioUnitario}}</td>
                <td class="col-tot">{{total}}</td>
            </tr>
            {{/each}}
        </tbody>
    </table>

    <!-- ── SON ────────────────────────────────────────────────────── -->
    <div class="son-section">SON: {{totalEnLetras}}</div>

    <!-- ── FOOTER SECTION ─────────────────────────────────────────── -->
    <div class="footer-section">
        <div class="observaciones-box">
            <div class="obs-title">OBSERVACIONES:</div>
            <p class="obs-text">{{observaciones}}</p>
            {{#if cotizTerminos}}
            <p class="obs-text" style="margin-top:6px;"><strong>TÉRMINOS:</strong> {{cotizTerminos}}</p>
            {{/if}}
            {{#if tipoDetraccion}}
            <div class="bank-block">
                <div class="bank-header">DETRACCIÓN</div>
                <p>
                    {{tipoDetraccion}}<br>
                    MONTO A DETRAER: S/ {{montoDetraccion}}<br>
                    {{#if cuentaBancoNacion}}CTA. BANCO DE LA NACIÓN: {{cuentaBancoNacion}}<br>{{/if}}
                    {{#if medioPagoDetraccion}}MEDIO DE PAGO: {{medioPagoDetraccion}}{{/if}}
                </p>
            </div>
            {{/if}}
        </div>

        <div class="totales-box">
            <div class="row"><span><strong>OP. GRAVADAS:</strong></span><span>{{monedaSimbolo}} {{mtoOperGravadas}}</span></div>
            <div class="row"><span><strong>OP. EXONERADAS:</strong></span><span>{{monedaSimbolo}} 0.00</span></div>
            <div class="row"><span><strong>OP. INAFECTAS:</strong></span><span>{{monedaSimbolo}} 0.00</span></div>
            <div class="row"><span><strong>OP. GRATUITAS:</strong></span><span>{{monedaSimbolo}} 0.00</span></div>
            <div class="row"><span><strong>SUB TOTAL:</strong></span><span>{{monedaSimbolo}} {{subTotal}}</span></div>
            {{#if descuento}}
            <div class="row"><span><strong>DESCUENTOS TOTAL:</strong></span><span>{{monedaSimbolo}} {{descuento}}</span></div>
            {{/if}}
            <div class="row"><span><strong>IGV 18%:</strong></span><span>{{monedaSimbolo}} {{mtoIGV}}</span></div>
            <div class="row total-final">
                <span><strong>MONTO TOTAL:</strong></span>
                <span>{{monedaSimbolo}} {{mtoImpVenta}}</span>
            </div>
        </div>
    </div>

    <!-- ── CUENTAS BANCARIAS (tabla compacta) ──────────────────────── -->
    {{#unless (eq mostrarCuentas false)}}
    {{#if cuentasBancarias.length}}
    <table class="bank-table">
        <thead>
            <tr><th>BANCO</th><th>MONEDA</th><th>CUENTA</th><th>CCI</th></tr>
        </thead>
        <tbody>
            {{#each cuentasBancarias}}
            <tr>
                <td class="bank-td-name">{{banco}}</td>
                <td>{{moneda}}</td>
                <td>{{numeroCuenta}}</td>
                <td>{{cci}}</td>
            </tr>
            {{/each}}
        </tbody>
    </table>
    {{/if}}
    {{/unless}}

    <!-- ── GRACIAS ─────────────────────────────────────────────────── -->
    <div class="footer-thanks">
        <p>GRACIAS POR ELEGIR {{nombreComercial}} PARA CUBRIR SUS REQUERIMIENTOS DE {{rubro}}</p>
        <p>VUELVA PRONTO</p>
    </div>

    <!-- ── BOTTOM STRIP ────────────────────────────────────────────── -->
    <div class="footer-bottom">
        <div class="usuario-label">USUARIO: {{usuario}}</div>
        <div class="marca-label">
            {{sistemaNombre}} ™<br>
            Comprobante emitido a través de {{sistemaUrl}}
        </div>
    </div>

</body>
</html>
