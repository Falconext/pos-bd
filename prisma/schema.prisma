}

model GuiaRemision {
  id        Int @id @default(autoincrement())
  empresaId Int

  // Información del documento
  tipoGuia      TipoGuiaRemision @default(REMITENTE) // Tipo de guía
  serie         String
  correlativo   Int
  fechaEmision  DateTime
  horaEmision   String?
  tipoDocumento String           @default("09") // Código SUNAT: 09=Remitente, 31=Transportista

  // Remitente (DespatchSupplierParty)
  remitenteRuc         String
  remitenteRazonSocial String
  remitenteDireccion   String

  // Destinatario (DeliveryCustomerParty)
  destinatarioTipoDoc     String
  destinatarioNumDoc      String
  destinatarioRazonSocial String

  // Shipment
  tipoTraslado   String // 01: Venta, 02: Compra, etc.
  modoTransporte String // 01: Transporte Público, 02: Transporte Privado
  pesoTotal      Decimal
  unidadPeso     String  @default("KGM")

  // Transportista (para transporte público)
  transportistaRuc         String?
  transportistaRazonSocial String?
  transportistaMTC         String? // Registro MTC

  // Para GRE-T: remitente real de los bienes (diferente al transportista)
  // En GRE-T, DespatchParty = quien envía la carga (puede ser otra empresa)
  greTRemitenteNumDoc      String? // RUC/DNI del remitente de los bienes
  greTRemitenteRazonSocial String? // Razón social del remitente de los bienes

  // Conductor/Vehículo (para transporte privado)
  conductorTipoDoc     String?
  conductorNumDoc      String?
  conductorNombre      String?
  conductorApellidos   String?
  conductorLicencia    String?
  vehiculoPlaca        String?
  vehiculoAutorizacion String?

  // Punto de partida
  partidaUbigeo                String
  partidaDireccion             String
  partidaCodigoEstablecimiento String?

  // Punto de llegada
  llegadaUbigeo                String
  llegadaDireccion             String
  llegadaCodigoEstablecimiento String?

  // Fecha de traslado
  fechaInicioTraslado DateTime

  // Flags opcionales
  retornoVehiculoVacio Boolean @default(false)
  retornoEnvasesVacios Boolean @default(false)
  transbordoProgramado Boolean @default(false)
  trasladoTotal        Boolean @default(false) // DAM o DS
  vehiculoM1oL         Boolean @default(false)
  datosTransportista   Boolean @default(false)

  // SUNAT
  estadoSunat       EstadoSunat @default(PENDIENTE)
  sunatXml          String?
  sunatCdrResponse  String?
  sunatCdrZip       String?
  sunatErrorMsg     String?
  documentoId       String? // ID del proveedor SUNAT
  s3XmlUrl          String?
  s3CdrUrl          String?
  s3PdfUrl          String?
  sunatRetriesCount Int         @default(0)
  sunatNextRetryAt  DateTime?
  sunatLastRetryAt  DateTime?

  // Observaciones
  observaciones String?

  // Auditoría
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt
  usuarioId     Int?
  clienteId     Int? // Destinatario si está registrado

  // Relaciones
  empresa        Empresa               @relation(fields: [empresaId], references: [id])
  usuario        Usuario?              @relation(fields: [usuarioId], references: [id])
  cliente        Cliente?              @relation(fields: [clienteId], references: [id])
  detalles       DetalleGuiaRemision[]
  whatsappEnvios WhatsAppEnvio[]

  sedeId Int?
  sede   Sede? @relation(fields: [sedeId], references: [id])

  @@unique([empresaId, serie, correlativo])
  @@index([empresaId, fechaEmision])
  @@index([estadoSunat])
}

model DetalleGuiaRemision {
  id             Int @id @default(autoincrement())
  guiaRemisionId Int
