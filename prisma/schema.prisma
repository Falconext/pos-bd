model EnvioDespacho {
  id               Int            @id @default(autoincrement())
  comprobanteId    Int            @unique
  comprobante      Comprobante    @relation(fields: [comprobanteId], references: [id], onDelete: Cascade)
  transportista    String?
  codigoGuia       String?
  estado           EstadoDespacho @default(PREPARANDO)
  observaciones    String?
  direccionDestino String?
  fechaEstimada    DateTime?
  historial        Json?
  // Coordinación de envío nacional
  tipoEnvio        String? // AGENCIA | DOMICILIO
  agenciaDestino   String? // Nombre de agencia destino (ej: "Shalom Cusco Centro")
  celularDest      String? // Celular del destinatario
  nroPaquetes      Int?           @default(1)
  turnoEnvio       String? // MANANA | TARDE | NOCHE
  tipoMercaderia   String? // Clasificación para el courier (Shalom)
  claveEnvio       String?
  nroOrden         String?
  claveOrden       String?
  establecimiento  String? // Local/sucursal desde donde despacha
  repartidorId     Int?
  repartidor       Repartidor?    @relation(fields: [repartidorId], references: [id], onDelete: SetNull)
  empaquetador       String? // Nombre del empaquetador
  // Datos del destinatario (Shalom)
  nombreDestinatario String? // Nombre completo del destinatario
  dniDestinatario    String? // DNI/documento del destinatario
  contenidoPaquete   String? // Descripción del contenido (ej: "1 Caja")
  montoCOD           Float?  // Monto a cobrar en destino (Shalom COD)
  costoEnvio         Float?  @default(0) // Monto cobrado al cliente o absorbido por el negocio
  pagarFlete         String? @default("NEGOCIO") // CLIENTE | NEGOCIO
  aplicacionMontoCliente String? @default("NEGOCIO") // ITEM_ENVIO | ADELANTO | NEGOCIO
  creadoEn           DateTime       @default(now())
  actualizadoEn      DateTime       @updatedAt

  @@index([comprobanteId])
  @@index([repartidorId])
}

model Repartidor {
