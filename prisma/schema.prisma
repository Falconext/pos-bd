  igv               Decimal                 @default(0)
  total             Decimal
  estado            EstadoPedidoTienda      @default(PENDIENTE)
  estadoEntrega     String                  @default("PENDIENTE")
  agenciaEnvio      String?
  estadoEnvio       String                  @default("SIN_ASIGNAR")
  medioPago         MedioPagoTienda         @default(YAPE)
  montoPagado       Decimal                 @default(0)
  saldoPendiente    Decimal                 @default(0)
