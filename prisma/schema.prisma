generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Plan {
  id                     Int             @id @default(autoincrement())
  nombre                 String
  plataforma             String          @default("falconext")
  producto               String          @default("facturacion")
  descripcion            String?
  limiteUsuarios         Int?
  maxSedes               Int?            @default(1)
  costo                  Decimal         @default(0)
  esPrueba               Boolean         @default(false)
  duracionDias           Int             @default(30)
  tipoFacturacion        String          @default("MENSUAL")
  tieneTienda            Boolean         @default(false)
  maxBanners             Int?            @default(3)
  maxImagenesProducto    Int?            @default(1)
  tieneBanners           Boolean         @default(false)
  tieneCulqi             Boolean         @default(false)
  tieneDeliveryGPS       Boolean         @default(false)
  tieneGaleria           Boolean         @default(false)
  maxComprobantes        Int?            @default(100)
  tieneTicketera         Boolean         @default(false)
  tieneGestionLotes      Boolean         @default(false)
  tieneGestionProvisiones Boolean         @default(false)
  tieneDescripcionRica   Boolean         @default(false)
  empresas               Empresa[]
  features               PlanFeature[]
  modulosAsignados       PlanModulo[]
  subModulosAsignados    PlanSubModulo[]

  @@unique([nombre, plataforma, producto])
  @@index([plataforma])
  @@index([producto])
  @@index([plataforma, producto])
}

model PlanFeature {
  id        Int      @id @default(autoincrement())
  planId    Int
  featureKey String
  enabled   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  plan      Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, featureKey])
  @@index([planId])
  @@index([featureKey])
}

model Ubigeo {
  codigo       String    @id
  departamento String
  provincia    String
  distrito     String
  empresas     Empresa[]
}

model Rubro {
  id         Int                 @id @default(autoincrement())
  nombre     String              @unique
  disenos    DisenoRubro?
  empresas   Empresa[]
  plantillas ProductoPlantilla[]
  features   RubroFeature[]
  fichasTecnicas FichaTecnicaPlantilla[]
}

model RubroFeature {
  id               Int      @id @default(autoincrement())
  rubroId          Int
  featureKey       String
  enabledByDefault Boolean  @default(false)
  config           Json?
  creadoEn         DateTime @default(now())
  actualizadoEn    DateTime @updatedAt

  rubro Rubro @relation(fields: [rubroId], references: [id], onDelete: Cascade)

  @@unique([rubroId, featureKey])
  @@index([featureKey])
}

model Empresa {
  id                      Int                           @id @default(autoincrement())
  ruc                     String                        @unique
  razonSocial             String
  direccion               String
  logo                    String?
  fechaActivacion         DateTime
  fechaExpiracion         DateTime
  planId                  Int
  estado                  EstadoType                    @default(ACTIVO)
  departamento            String?
  distrito                String?
  provincia               String?
  ubigeo                  String?
  providerToken           String?
  billingProvider         BillingProvider               @default(QPSE)
  billingApiBaseUrl       String?
  billingApiDemoBaseUrl   String?
  billingApiToken         String?
  billingApiUser          String?
  billingApiPassword      String?
  tokenCreatedAt          DateTime?
  tokenUpdatedAt          DateTime?
  empresaUbigeo           String?
  nombreComercial         String?
  rubroId                 Int?
  providerId              String?
  tipoEmpresa             TipoEmpresa                   @default(FORMAL)
  aceptaEfectivo          Boolean                       @default(true)
  colorPrimario           String?                       @default("#000000")
  colorSecundario         String?                       @default("#ffffff")
  descripcionTienda       String?
  facebookUrl             String?
  horarioAtencion         String?
  instagramUrl            String?
  plinNumero              String?
  plinQrUrl               String?
  slugTienda              String?                       @unique
  tiktokUrl               String?
  whatsappTienda          String?
  whatsappProvider        WhatsAppProvider              @default(PLATFORM)
  whatsappApiToken        String?
  whatsappPhoneNumberId   String?
  whatsappBusinessId      String?
  whatsappActivo          Boolean                       @default(true)
  yapeNumero              String?
  yapeQrUrl               String?
  aceptaEnvio             Boolean                       @default(true)
  aceptaRecojo            Boolean                       @default(true)
  esAgenteRetencion       Boolean                       @default(false)
  ticketLogoSize          Int?                          @default(96)
  usaCodigoBarrasManual   Boolean?
  usarPrecioLoteFefo      Boolean                       @default(false)
  costoActivacionReseller Decimal?                      @default(0)
  costoEnvioFijo          Decimal?                      @default(0)
  envioGratisDesdeSoles   Decimal?                      @default(0)
  minimoCompra            Decimal?                      @default(0)
  direccionRecojo         String?
  tiempoPreparacionMin    Int?                          @default(30)
  disenoOverride          String?
  directorTecnico         String?
  banners                 Banner[]
  categorias              Categoria[]
  clientes                Cliente[]
  compras                 Compra[]
  comprobantes            Comprobante[]
  ubicacion               Ubigeo?                       @relation(fields: [empresaUbigeo], references: [codigo])
  plan                    Plan                          @relation(fields: [planId], references: [id])
  rubro                   Rubro?                        @relation(fields: [rubroId], references: [id])
  marcas                  Marca[]
  movimientosCaja         MovimientoCaja[]
  movimientosKardex       MovimientoKardex[]
  Notificacion            Notificacion[]
  pagos                   Pago[]
  pagosCompra             PagoCompra[]
  pedidosTienda           PedidoTienda[]
  preferenciasTabla       PreferenciaTabla[]
  productos               Producto[]
  usuarios                Usuario[]
  whatsappEnvios          WhatsAppEnvio[]
  combos                  Combo[]
  gruposModificadores     GrupoModificador[]
  guiasRemision           GuiaRemision[]
  sedes                   Sede[]
  recetasProduccion       RecetaProduccion[]
  ordenesProduccion       OrdenProduccion[]
  movimientosProduccion   MovimientoProduccion[]
  vinculosXmlProductos    VinculoProductoProveedorXml[]
  imagenesProductoIa      ImagenProductoAprobadaIa[]
  reservas                Reserva[]
  repartidores            Repartidor[]
  despachoMensajeTemplate DespachoMensajeTemplate?

  bancoNombre         String?
  numeroCuenta        String?
  cci                 String?
  monedaCuenta        String?              @default("SOLES")
  resellerId          Int?
  reseller            Reseller?            @relation(fields: [resellerId], references: [id])
  resellerMovimientos ResellerMovimiento[]
  brand               String               @default("falconext")
  producto            String               @default("facturacion")
  hotelTenantId       String?
  hotelAdminUserId    String?
  hotelSyncAt         DateTime?
  usuarioPse          String?
  contrasenaPse       String?
  usaDemo             Boolean              @default(false)
  metodoSalidaLotes   String               @default("LIFO")
  notas               NotaEmpresa[]
  logs                EmpresaLog[]
  gastosOperativos    GastoOperativo[]
  comisionesVendedor  ComisionVendedor[]
  campanas            CampanaMarketing[]
  series              EmpresaSerie[]
  productoSeries      ProductoSerie[]
  reclamosGarantia    ReclamoGarantia[]
  productoReviews     ProductoReview[]
  fichasTecnicas      FichaTecnicaPlantilla[]
  cuentasBancarias    CuentaBancaria[]
  doctors             Doctor[]

  @@index([providerToken])
  @@index([slugTienda])
  @@index([brand])
  @@index([producto])
  @@index([brand, producto])
  @@index([whatsappProvider])
}

model EmpresaSerie {
  id            Int      @id @default(autoincrement())
  empresaId     Int
  tipoDoc       String
  serie         String
  correlativo   Int      @default(1)
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([empresaId, tipoDoc, serie])
  @@index([empresaId, tipoDoc, activo])
}

model Usuario {
  id                     Int                     @id @default(autoincrement())
  nombre                 String
  dni                    String
  celular                String
  email                  String                  @unique
  password               String
  rol                    Rol
  empresaId              Int?
  estado                 EstadoType              @default(ACTIVO)
  telefono               String?
  permisos               String?
  compras                Compra[]
  comprobantes           Comprobante[]
  historialEstadosPedido HistorialEstadoPedido[]
  movimientosCaja        MovimientoCaja[]
  movimientosKardex      MovimientoKardex[]
  Notificacion           Notificacion[]
  pagos                  Pago[]
  pagosCompra            PagoCompra[]
  preferenciasTabla      PreferenciaTabla[]
  refreshTokens          RefreshToken[]
  empresa                Empresa?                @relation(fields: [empresaId], references: [id])
  whatsappEnvios         WhatsAppEnvio[]
  guiasRemision          GuiaRemision[]
  sedeId                 Int?
  sede                   Sede?                   @relation(fields: [sedeId], references: [id])
  resellerId             Int?
  reseller               Reseller?               @relation(fields: [resellerId], references: [id])
  sistemaNegocio         String?
  sistemaProducto        String?
  sedesAsignadas         UsuarioSede[]
  subModulosAsignados    UsuarioSubModulo[]
  passwordResetToken     String?
  passwordResetExpires   DateTime?
  ordenesProduccion      OrdenProduccion[]
  movimientosProduccion  MovimientoProduccion[]
  comisiones             ComisionVendedor[]
  campanas               CampanaMarketing[]
  comisionGlobal         Decimal?                @db.Decimal(12, 2)
  comisionGlobalFija     Decimal?                @db.Decimal(12, 2)
  comisionGlobalVenta    Decimal?                @db.Decimal(12, 2)
}

model Categoria {
  id        Int        @id @default(autoincrement())
  nombre    String
  imagenUrl String?
  empresaId Int?
  empresa   Empresa?   @relation(fields: [empresaId], references: [id])
  productos Producto[]
  fichasTecnicas FichaTecnicaPlantilla[]
}

model FichaTecnicaPlantilla {
  id             Int      @id @default(autoincrement())
  nombre         String
  descripcion    String?
  rubroId        Int?
  categoriaId    Int?
  empresaId      Int?
  campos         Json
  destacados     Json?
  activo         Boolean  @default(true)
  creadoEn       DateTime @default(now())
  actualizadoEn  DateTime @updatedAt

  rubro     Rubro?     @relation(fields: [rubroId], references: [id], onDelete: Cascade)
  categoria Categoria? @relation(fields: [categoriaId], references: [id], onDelete: Cascade)
  empresa   Empresa?   @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([rubroId])
  @@index([categoriaId])
  @@index([empresaId])
  @@index([activo])
}

model UnidadMedida {
  id        Int        @id @default(autoincrement())
  codigo    String     @unique
  nombre    String
  productos Producto[]
}

model Marca {
  id        Int        @id @default(autoincrement())
  nombre    String
  imagenUrl String?
  empresaId Int?
  empresa   Empresa?   @relation(fields: [empresaId], references: [id])
  productos Producto[]

  @@unique([empresaId, nombre])
}

model Producto {
  id                       Int                           @id @default(autoincrement())
  codigo                   String
  descripcion              String
  categoriaId              Int?
  unidadMedidaId           Int
  tipoAfectacionIGV        String
  precioUnitario           Decimal
  valorUnitario            Decimal
  igvPorcentaje            Decimal                       @default(18.00)
  stock                    Int
  estado                   EstadoType                    @default(ACTIVO)
  creadoEn                 DateTime                      @default(now())
  empresaId                Int?
  costoPromedio            Decimal?                      @default(0)
  costoFijo                Decimal?                      @default(0)
  comisionPorVenta         Decimal?
  comisionPorcentaje       Decimal?
  stockMaximo              Int?
  stockMinimo              Int?                          @default(0)
  descripcionLarga         String?
  destacado                Boolean                       @default(false)
  imagenUrl                String?
  imagenesExtra            String?
  publicarEnTienda         Boolean                       @default(true)
  marcaId                  Int?
  ratingAvg                Decimal?                      @default(0)
  ratingCount              Int?                          @default(0)
  codigoBarras             String?
  codigoDigemid            String?
  concentracion            String?
  controlado               Boolean                       @default(false)
  factorConversion         Int                           @default(1)
  fechaFinOferta           DateTime?
  fechaInicioOferta        DateTime?
  laboratorio              String?
  ofertaActiva             Boolean                       @default(false)
  pesoGramos               Decimal?
  precioOferta             Decimal?
  presentacion             String?
  principioActivo          String?
  refrigerado              Boolean                       @default(false)
  requiereReceta           Boolean                       @default(false)
  unidadCompra             String?
  unidadVenta              String?
  volumenMl                Decimal?
  preciosMayorista         Json?
  atributosTecnicos        Json?
  localizacion             String?
  porcentajeVenta          Int                           @default(100)
  porcentajeProvision      Int                           @default(0)
  detalleCompras           DetalleCompra[]
  detalleComprobantes      DetalleComprobante[]
  galeria                  GaleriaProducto[]
  itemsPedido              ItemPedidoTienda[]
  movimientosKardex        MovimientoKardex[]
  productoPadreId          Int?
  opcionesAtributos        Json?
  valoresAtributos         Json?

  categoria                Categoria?                    @relation(fields: [categoriaId], references: [id])
  productoPadre            Producto?                     @relation("ProductoVariantes", fields: [productoPadreId], references: [id])
  variantes                Producto[]                    @relation("ProductoVariantes")
  empresa                  Empresa?                      @relation(fields: [empresaId], references: [id])
  marca                    Marca?                        @relation(fields: [marcaId], references: [id])
  unidadMedida             UnidadMedida                  @relation(fields: [unidadMedidaId], references: [id])
  comboItems               ComboItem[]
  gruposModificadores      ProductoGrupoModificador[]
  lotes                    ProductoLote[]
  detallesGuiaRemision     DetalleGuiaRemision[]
  stocks                   ProductoStock[]
  recetasComoProductoFinal RecetaProduccion[]            @relation("RecetaProductoFinal")
  recetasComoInsumo        RecetaComponente[]            @relation("RecetaProductoInsumo")
  ordenesComoProductoFinal OrdenProduccion[]             @relation("OrdenProductoFinal")
  componentesProduccion    OrdenProduccionComponente[]   @relation("OrdenProductoInsumo")
  movimientosProduccion    MovimientoProduccion[]
  vinculosProveedorXml     VinculoProductoProveedorXml[]
  reservas                 Reserva[]
  campanas                 CampanaMarketing[]
  seriesInventario         ProductoSerie[]
  reviews                  ProductoReview[]

  @@unique([empresaId, codigo])
  @@unique([empresaId, codigoDigemid])
  @@index([empresaId, publicarEnTienda])
  @@index([marcaId])
  @@index([empresaId, codigoBarras])
}

enum EstadoProductoReview {
  PENDIENTE
  APROBADO
  RECHAZADO
  OCULTO
}

model ProductoReview {
  id              Int                  @id @default(autoincrement())
  empresaId       Int
  productoId      Int
  pedidoId        Int?
  clienteId       Int?
  clienteNombre   String
  clienteEmail    String?
  clienteTelefono String?
  rating          Int
  comentario      String
  estado          EstadoProductoReview @default(PENDIENTE)
  compraVerificada Boolean             @default(false)
  token           String?              @unique
  creadoEn        DateTime             @default(now())
  actualizadoEn   DateTime             @updatedAt
  aprobadoEn      DateTime?

  empresa  Empresa       @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  producto Producto      @relation(fields: [productoId], references: [id], onDelete: Cascade)
  pedido   PedidoTienda? @relation(fields: [pedidoId], references: [id], onDelete: SetNull)
  cliente  Cliente?      @relation(fields: [clienteId], references: [id], onDelete: SetNull)

  @@index([empresaId, estado, creadoEn])
  @@index([productoId, estado])
  @@index([pedidoId])
}

model RecetaProduccion {
  id                      Int                @id @default(autoincrement())
  empresaId               Int
  productoFinalId         Int
  codigo                  String
  nombre                  String
  version                 Int                @default(1)
  rendimientoObjetivo     Decimal
  unidadRendimiento       String
  mermaObjetivoPorcentaje Decimal?           @default(0)
  activo                  Boolean            @default(true)
  observaciones           String?
  creadoEn                DateTime           @default(now())
  actualizadoEn           DateTime           @updatedAt
  empresa                 Empresa            @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  productoFinal           Producto           @relation("RecetaProductoFinal", fields: [productoFinalId], references: [id], onDelete: Cascade)
  componentes             RecetaComponente[]
  ordenes                 OrdenProduccion[]

  @@unique([empresaId, codigo, version])
  @@index([empresaId, activo])
  @@index([productoFinalId])
}

model RecetaComponente {
  id                      Int              @id @default(autoincrement())
  recetaId                Int
  productoInsumoId        Int
  orden                   Int              @default(0)
  cantidadBase            Decimal
  unidadBase              String
  mermaEsperadaPorcentaje Decimal?         @default(0)
  esOpcional              Boolean          @default(false)
  creadoEn                DateTime         @default(now())
  actualizadoEn           DateTime         @updatedAt
  receta                  RecetaProduccion @relation(fields: [recetaId], references: [id], onDelete: Cascade)
  productoInsumo          Producto         @relation("RecetaProductoInsumo", fields: [productoInsumoId], references: [id], onDelete: Cascade)

  @@unique([recetaId, productoInsumoId, orden])
  @@index([recetaId])
  @@index([productoInsumoId])
}

model OrdenProduccion {
  id                   Int                         @id @default(autoincrement())
  empresaId            Int
  recetaId             Int?
  productoFinalId      Int
  loteProduccion       String
  fechaProgramada      DateTime?
  fechaInicio          DateTime?
  fechaFin             DateTime?
  cantidadObjetivo     Decimal
  cantidadProducida    Decimal                     @default(0)
  mermaTotal           Decimal                     @default(0)
  estado               EstadoProduccion            @default(BORRADOR)
  observaciones        String?
  usuarioResponsableId Int?
  creadoEn             DateTime                    @default(now())
  actualizadoEn        DateTime                    @updatedAt
  empresa              Empresa                     @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  receta               RecetaProduccion?           @relation(fields: [recetaId], references: [id], onDelete: SetNull)
  productoFinal        Producto                    @relation("OrdenProductoFinal", fields: [productoFinalId], references: [id], onDelete: Cascade)
  usuarioResponsable   Usuario?                    @relation(fields: [usuarioResponsableId], references: [id], onDelete: SetNull)
  componentes          OrdenProduccionComponente[]
  movimientos          MovimientoProduccion[]

  @@unique([empresaId, loteProduccion])
  @@index([empresaId, estado])
  @@index([productoFinalId, fechaInicio])
  @@index([usuarioResponsableId])
}

model OrdenProduccionComponente {
  id                Int             @id @default(autoincrement())
  ordenProduccionId Int
  productoInsumoId  Int
  cantidadTeorica   Decimal
  cantidadConsumida Decimal         @default(0)
  mermaCantidad     Decimal         @default(0)
  unidad            String
  costoUnitario     Decimal?        @default(0)
  costoTotal        Decimal?        @default(0)
  observacion       String?
  creadoEn          DateTime        @default(now())
  actualizadoEn     DateTime        @updatedAt
  ordenProduccion   OrdenProduccion @relation(fields: [ordenProduccionId], references: [id], onDelete: Cascade)
  productoInsumo    Producto        @relation("OrdenProductoInsumo", fields: [productoInsumoId], references: [id], onDelete: Cascade)

  @@unique([ordenProduccionId, productoInsumoId])
  @@index([ordenProduccionId])
  @@index([productoInsumoId])
}

model MovimientoProduccion {
  id                 Int                      @id @default(autoincrement())
  ordenProduccionId  Int
  empresaId          Int
  productoId         Int
  tipoMovimiento     TipoMovimientoProduccion
  cantidad           Decimal
  unidad             String
  costoUnitario      Decimal?                 @default(0)
  costoTotal         Decimal?                 @default(0)
  mermaCantidad      Decimal?                 @default(0)
  loteReferencia     String?
  fecha              DateTime                 @default(now())
  usuarioId          Int?
  observacion        String?
  movimientoKardexId Int?
  ordenProduccion    OrdenProduccion          @relation(fields: [ordenProduccionId], references: [id], onDelete: Cascade)
  empresa            Empresa                  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  producto           Producto                 @relation(fields: [productoId], references: [id], onDelete: Cascade)
  usuario            Usuario?                 @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  movimientoKardex   MovimientoKardex?        @relation(fields: [movimientoKardexId], references: [id], onDelete: SetNull)

  @@index([ordenProduccionId, fecha])
  @@index([empresaId, fecha])
  @@index([productoId])
  @@index([usuarioId])
  @@index([movimientoKardexId])
}

model TipoDocumento {
  id          Int       @id @default(autoincrement())
  codigo      String    @unique
  descripcion String
  clientes    Cliente[]
}

model Cliente {
  id              Int            @id @default(autoincrement())
  nombre          String
  nroDoc          String
  direccion       String?
  email           String?
  telefono        String?
  empresaId       Int?
  estado          EstadoType     @default(ACTIVO)
  tipoDocumentoId Int?
  departamento    String?
  distrito        String?
  provincia       String?
  ubigeo          String?
  persona         PersonaType    @default(CLIENTE)
  // Campos médicos (farmacia/clínica) — opcionales, no afectan otros rubros
  grupoSanguineo  String?
  alergias        String?
  fechaNacimiento DateTime?
  medicoTratanteId Int?
  empresa         Empresa?       @relation(fields: [empresaId], references: [id])
  tipoDocumento   TipoDocumento? @relation(fields: [tipoDocumentoId], references: [id])
  medicoTratante  Doctor?        @relation("PacienteMedico", fields: [medicoTratanteId], references: [id])
  compras         Compra[]
  comprobantes    Comprobante[]
  guiasRemision   GuiaRemision[]
  productoReviews ProductoReview[]
  detallesComosPaciente DetalleComprobante[] @relation("PacienteDetalle")
}

model Doctor {
  id           Int      @id @default(autoincrement())
  empresaId    Int
  nombre       String
  cmp          String?
  especialidad String?
  telefono     String?
  email        String?
  estado       EstadoType @default(ACTIVO)
  empresa      Empresa  @relation(fields: [empresaId], references: [id])
  pacientes    Cliente[] @relation("PacienteMedico")
  detalles     DetalleComprobante[] @relation("MedicoDetalle")

  @@index([empresaId])
}

model TipoOperacion {
  id           Int           @id @default(autoincrement())
  codigo       String        @unique
  descripcion  String
  comprobantes Comprobante[]
}

model MotivoNota {
  id           Int           @id @default(autoincrement())
  tipo         TipoNota
  codigo       String
  descripcion  String
  comprobantes Comprobante[] @relation("ComprobanteMotivo")

  @@unique([tipo, codigo])
}

model TipoDetraccion {
  id           Int           @id @default(autoincrement())
  codigo       String        @unique
  descripcion  String
  porcentaje   Decimal
  activo       Boolean       @default(true)
  comprobantes Comprobante[]
}

model MedioPagoDetraccion {
  id           Int           @id @default(autoincrement())
  codigo       String        @unique
  descripcion  String
  activo       Boolean       @default(true)
  comprobantes Comprobante[]
}

model Comprobante {
  id                    Int                  @id @default(autoincrement())
  ublVersion            String               @default("2.1")
  tipoDoc               String
  serie                 String
  correlativo           Int
  fechaEmision          DateTime
  formaPagoTipo         String
  formaPagoMoneda       String
  tipoMoneda            String
  observaciones         String?
  mtoOperGravadas       Float
  mtoIGV                Float
  valorVenta            Float
  totalImpuestos        Float
  subTotal              Float
