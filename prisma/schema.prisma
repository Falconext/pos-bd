model IngresoSistema {
  id            Int      @id @default(autoincrement())
  concepto      String
  tipo          String // SUSCRIPCION, ACTIVACION, SOPORTE, PERSONALIZADO, OTROS
  monto         Decimal
  fecha         DateTime
  descripcion   String?
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

