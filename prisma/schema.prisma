  MANTENIMIENTO
  AVERIADO
  FUERA_SERVICIO
}

enum TipoCombustibleLogistica {
  GASOLINA
  DIESEL
  GLP
  GNV
  ELECTRICO
  HIBRIDO
}

enum OrigenPedidoLogistica {
  MANUAL
  EXCEL
  API
  WEBHOOK
  ECOMMERCE
  FALCONEXT_ERP
  FALCONEXT
}

enum EstadoPedidoLogistica {
  PENDIENTE
  VALIDADO
  ASIGNADO
  LISTO_RECOGER
  RECOGIDO
  EN_TRANSITO
  LLEGANDO
  EN_UBICACION
  ENTREGADO
  ENTREGA_PARCIAL
  FALLIDO
  DEVUELTO
  REPROGRAMADO
  CANCELADO
