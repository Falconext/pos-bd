  estadoNuevo    EstadoPedidoTienda
  usuarioId      Int?
  notas          String?
  creadoEn       DateTime            @default(now())
  pedido         PedidoTienda        @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  usuario        Usuario?            @relation(fields: [usuarioId], references: [id])

  @@index([pedidoId])
  @@index([creadoEn])
}

