}

model DetalleComprobante {
  id                Int           @id @default(autoincrement())
  comprobanteId     Int
  productoId        Int?
  unidad            String
  descripcion       String
  cantidad          Float
  mtoValorUnitario  Float
  mtoValorVenta     Float
  mtoBaseIgv        Float
  porcentajeIgv     Float
  igv               Float
  tipAfeIgv         Int
  totalImpuestos    Float
  numerosSerie      Json?
  mtoPrecioUnitario Float
  // Farmacia: trazabilidad de lote dispensado
  loteId            Int?
  // Farmacia: datos de receta médica y medicamentos controlados
  numeroReceta      String?
  dniPaciente       String?
  nombrePaciente    String?
  medicoNombre      String?
  // FKs opcionales — enlazan con entidades Doctor/Cliente si existen; los campos String se mantienen como fallback
  medicoId          Int?
  pacienteId        Int?
  comprobante       Comprobante   @relation(fields: [comprobanteId], references: [id])
  producto          Producto?     @relation(fields: [productoId], references: [id])
  lote              ProductoLote? @relation(fields: [loteId], references: [id])
  medico            Doctor?       @relation("MedicoDetalle", fields: [medicoId], references: [id])
  paciente          Cliente?      @relation("PacienteDetalle", fields: [pacienteId], references: [id])
  seriesVendidas    ProductoSerie[]
}

enum EstadoProductoSerie {
  DISPONIBLE
  VENDIDO
  RESERVADO
  BAJA
}

model ProductoSerie {
  id                   Int                 @id @default(autoincrement())
  empresaId            Int
  productoId           Int
  sedeId               Int?
  numeroSerie          String
  estado               EstadoProductoSerie @default(DISPONIBLE)
  garantiaMeses        Int?
  garantiaHasta        DateTime?
  comprobanteId        Int?
  detalleComprobanteId Int?
  compraId             Int?
  compraDetalleId      Int?
  observacion          String?
  creadoEn             DateTime            @default(now())
  actualizadoEn        DateTime            @updatedAt

  empresa            Empresa             @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  producto           Producto            @relation(fields: [productoId], references: [id], onDelete: Cascade)
  sede               Sede?               @relation(fields: [sedeId], references: [id], onDelete: SetNull)
  comprobante        Comprobante?        @relation(fields: [comprobanteId], references: [id], onDelete: SetNull)
  detalleComprobante DetalleComprobante? @relation(fields: [detalleComprobanteId], references: [id], onDelete: SetNull)
  compra             Compra?             @relation(fields: [compraId], references: [id], onDelete: SetNull)
  compraDetalle      DetalleCompra?      @relation(fields: [compraDetalleId], references: [id], onDelete: SetNull)
  reclamos           ReclamoGarantia[]

  @@unique([empresaId, numeroSerie])
  @@index([empresaId, productoId, estado])
  @@index([comprobanteId])
  @@index([detalleComprobanteId])
  @@index([compraId])
}

enum EstadoReclamo {
  ABIERTO
  EN_PROCESO
  RESUELTO
  CERRADO
}

model ReclamoGarantia {
  id              Int           @id @default(autoincrement())
  empresaId       Int
  productoSerieId Int
  descripcion     String
