  nombreComercial   String
  principioActivo   String?
  formaFarmaceutica String?
  concentracion     String?
  presentacion      String?
  laboratorio       String?
  registroSanitario String?
  condicionVenta    String?
  estado            String?
  codigoBarras      String?
