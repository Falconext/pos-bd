  costoUnitario         Decimal?
  valorTotal            Decimal?
  fecha                 DateTime               @default(now())
  usuarioId             Int?
  observacion           String?
  lote                  String?
  fechaVencimiento      DateTime?
  compraId              Int?
  compra                Compra?                @relation(fields: [compraId], references: [id])
