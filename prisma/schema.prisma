enum TipoParadaLogistica {
  ORIGEN
  ENTREGA
  RECOGIDA
  DESCANSO
  COMBUSTIBLE
  RETORNO
}

model ConductorLogistica {
  id                  Int                      @id @default(autoincrement())
  empresaId           Int
  repartidorId        Int?                     @unique // Relación opcional con el Repartidor base
  nombre              String
  apellido            String
  dni                 String?
  celular             String?
  email               String?
  nroLicencia         String?
  tipoLicencia        String?
  vencimientoLicencia DateTime?
  tipoEmpleo          String?                  @default("EVENTUAL")
  estado              EstadoConductorLogistica @default(DISPONIBLE)

  // Scoring y Gamificación
  scorePromedio    Decimal @default(100) @db.Decimal(5, 2)
  nivelActual      Int     @default(1)
  xpAcumulada      Int     @default(0)
  entregasExitosas Int     @default(0)
  entregasFallidas Int     @default(0)

  // Ubicación Live
  lat             Decimal?  @db.Decimal(10, 8)
  lng             Decimal?  @db.Decimal(11, 8)
  ultimaUbicacion DateTime?

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  empresa              Empresa                       @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  repartidor           Repartidor?                   @relation(fields: [repartidorId], references: [id], onDelete: SetNull)
  despachos            DespachoLogistica[]
  asignacionesVehiculo AsignacionVehiculoLogistica[]
  paradas              ParadaRutaLogistica[]
  documentos           DocumentoLogistica[]

  @@index([empresaId])
  @@index([empresaId, estado])
}

model TipoVehiculoLogistica {
  id                 Int      @id @default(autoincrement())
  empresaId          Int
  nombre             String // Moto, Van, Camioneta, Camión
  capacidadPesoKg    Decimal  @db.Decimal(10, 2)
  capacidadVolumenM3 Decimal  @db.Decimal(10, 2)
  costoPromedioKm    Decimal? @db.Decimal(10, 2)
  creadoEn           DateTime @default(now())

  empresa   Empresa             @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  vehiculos VehiculoLogistica[]

  @@index([empresaId])
}

model VehiculoLogistica {
  id             Int                     @id @default(autoincrement())
  empresaId      Int
  tipoVehiculoId Int
  placa          String
  marca          String
  modelo         String?
  anio           Int?
  estado         EstadoVehiculoLogistica @default(DISPONIBLE)

  // Especificaciones
  capacidadPesoKg    Decimal                  @db.Decimal(10, 2) // Sobrescribe el default del tipo si aplica
  capacidadVolumenM3 Decimal                  @db.Decimal(10, 2) // Sobrescribe el default del tipo si aplica
  tipoCombustible    TipoCombustibleLogistica
  tieneRefrigeracion Boolean                  @default(false)
  tieneGPSIntegrado  Boolean                  @default(false)

  // Telemetría / Estado
  odometroActual       Int  @default(0)
  proximoMantenimiento Int?

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  empresa        Empresa                       @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  tipoVehiculo   TipoVehiculoLogistica         @relation(fields: [tipoVehiculoId], references: [id], onDelete: Restrict)
  despachos      DespachoLogistica[]
  asignaciones   AsignacionVehiculoLogistica[]
  mantenimientos MantenimientoLogistica[]
  combustibles   CombustibleLogistica[]
  peajes         PeajeLogistica[]
  documentos     DocumentoLogistica[]
  dispositivosGps DispositivoGpsLogistica[]

  @@unique([empresaId, placa])
  @@index([empresaId])
  @@index([empresaId, estado])
}

model AsignacionVehiculoLogistica {
  id          Int       @id @default(autoincrement())
  empresaId   Int
  conductorId Int
  vehiculoId  Int
  fechaInicio DateTime  @default(now())
  fechaFin    DateTime?
  kmInicio    Int?
  kmFin       Int?
  notas       String?

  empresa   Empresa            @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  conductor ConductorLogistica @relation(fields: [conductorId], references: [id], onDelete: Cascade)
  vehiculo  VehiculoLogistica  @relation(fields: [vehiculoId], references: [id], onDelete: Cascade)

  @@index([empresaId])
  @@index([conductorId])
  @@index([vehiculoId])
}

enum TipoMantenimientoLogistica {
  PREVENTIVO
  CORRECTIVO
  EMERGENCIA
  INSPECCION
}

enum EstadoMantenimientoLogistica {
  PROGRAMADO
  EN_PROCESO
  COMPLETADO
  CANCELADO
}

/// Historial de mantenimientos de la flota (preventivo/correctivo) con costos,
/// taller, kilometraje y próximo servicio. Alimenta las alertas de flota.
model MantenimientoLogistica {
  id         Int                          @id @default(autoincrement())
  empresaId  Int
  vehiculoId Int
  tipo       TipoMantenimientoLogistica   @default(PREVENTIVO)
  estado     EstadoMantenimientoLogistica @default(PROGRAMADO)

  descripcion String
  taller      String?

  // Fechas
  fechaProgramada DateTime
  fechaRealizado  DateTime?

  // Costo y odómetro
  costo      Decimal @default(0) @db.Decimal(10, 2)
  odometroKm Int?

  // Próximo servicio (para alertas de vencimiento)
  proximoMantenimientoKm    Int?
  proximoMantenimientoFecha DateTime?

  evidenciaUrl String?
  notas        String?

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  empresa  Empresa           @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  vehiculo VehiculoLogistica @relation(fields: [vehiculoId], references: [id], onDelete: Cascade)

  @@index([empresaId])
  @@index([empresaId, estado])
  @@index([vehiculoId])
  @@index([fechaProgramada])
}

/// Registro de cargas de combustible por vehículo (control de consumo y gasto).
model CombustibleLogistica {
  id         Int                      @id @default(autoincrement())
  empresaId  Int
  vehiculoId Int

  fecha           DateTime
  tipoCombustible TipoCombustibleLogistica @default(GASOLINA)
  cantidadLitros  Decimal                  @db.Decimal(10, 2)
  costoTotal      Decimal                  @db.Decimal(10, 2)
  costoPorLitro   Decimal?                 @db.Decimal(10, 2)
  odometroKm      Int?
  estacion        String?
  numeroComprobante String?
  evidenciaUrl    String?
  notas           String?

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  empresa  Empresa           @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  vehiculo VehiculoLogistica @relation(fields: [vehiculoId], references: [id], onDelete: Cascade)

  @@index([empresaId])
  @@index([vehiculoId])
  @@index([fecha])
}

enum TipoPeajeLogistica {
  PEAJE
  MULTA
  INFRACCION
}

enum EstadoPeajeLogistica {
  PENDIENTE
  PAGADO
  ANULADO
}

/// Peajes, multas e infracciones asociadas a un vehículo (con comprobante/recibo).
model PeajeLogistica {
  id         Int                  @id @default(autoincrement())
  empresaId  Int
  vehiculoId Int?

  tipo   TipoPeajeLogistica   @default(PEAJE)
  estado EstadoPeajeLogistica @default(PENDIENTE)

  fecha       DateTime
  monto       Decimal  @db.Decimal(10, 2)
  lugar       String?
  descripcion String?
  placa       String?
  comprobanteUrl String?
  reciboPagoUrl  String?
  notas       String?

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  empresa  Empresa            @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  vehiculo VehiculoLogistica? @relation(fields: [vehiculoId], references: [id], onDelete: SetNull)

  @@index([empresaId])
  @@index([empresaId, estado])
  @@index([vehiculoId])
  @@index([fecha])
}

enum EntidadDocumentoLogistica {
  VEHICULO
  CONDUCTOR
}

/// Documentos con fecha de vencimiento (SOAT, revisión técnica, seguro, licencia,
/// DNI, etc.) asociados a un vehículo o conductor. Alimenta las alertas de vencimiento.
model DocumentoLogistica {
  id        Int                       @id @default(autoincrement())
  empresaId Int
  entidad   EntidadDocumentoLogistica

  vehiculoId  Int?
  conductorId Int?

  tipo   String // SOAT, REVISION_TECNICA, SEGURO, TARJETA_PROPIEDAD, LICENCIA, DNI, ...
  numero String?

  fechaEmision     DateTime?
  fechaVencimiento DateTime

  archivoUrl String?
  notas      String?

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  empresa   Empresa             @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  vehiculo  VehiculoLogistica?  @relation(fields: [vehiculoId], references: [id], onDelete: Cascade)
  conductor ConductorLogistica? @relation(fields: [conductorId], references: [id], onDelete: Cascade)

  @@index([empresaId])
  @@index([empresaId, fechaVencimiento])
  @@index([vehiculoId])
  @@index([conductorId])
}

/// Dispositivo GPS (hardware o app) que reporta posiciones. Cada uno tiene un
/// token para ingestión de ubicaciones y puede asignarse a un vehículo.
model DispositivoGpsLogistica {
  id            Int       @id @default(autoincrement())
  empresaId     Int
  nombre        String
  identificador String // IMEI o serial
  token         String    @unique @default(cuid())
  vehiculoId    Int?
  activo        Boolean   @default(true)
  ultimaConexion DateTime?
  ultimaLat     Decimal?  @db.Decimal(10, 8)
  ultimaLng     Decimal?  @db.Decimal(11, 8)

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  empresa    Empresa                   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  vehiculo   VehiculoLogistica?        @relation(fields: [vehiculoId], references: [id], onDelete: SetNull)
  posiciones PosicionGpsLogistica[]
  eventos    EventoGeocercaLogistica[]

  @@unique([empresaId, identificador])
  @@index([empresaId])
}

/// Histórico de posiciones reportadas por un dispositivo GPS.
model PosicionGpsLogistica {
  id            Int      @id @default(autoincrement())
  empresaId     Int
  dispositivoId Int
  lat           Decimal  @db.Decimal(10, 8)
  lng           Decimal  @db.Decimal(11, 8)
  velocidad     Decimal? @db.Decimal(6, 2)
  rumbo         Int?
  timestamp     DateTime @default(now())

  dispositivo DispositivoGpsLogistica @relation(fields: [dispositivoId], references: [id], onDelete: Cascade)

  @@index([empresaId])
  @@index([dispositivoId, timestamp])
}

enum TipoGeocercaLogistica {
  CIRCULO
  POLIGONO
}

enum TipoEventoGeocercaLogistica {
  ENTRADA
  SALIDA
}

/// Geocerca (círculo o polígono) para vigilar zonas y generar alertas de
/// entrada/salida de la flota.
model GeocercaLogistica {
  id          Int                   @id @default(autoincrement())
  empresaId   Int
  nombre      String
  descripcion String?
  tipo        TipoGeocercaLogistica @default(CIRCULO)

  // Círculo
  lat   Decimal? @db.Decimal(10, 8)
  lng   Decimal? @db.Decimal(11, 8)
  radio Decimal? @db.Decimal(10, 2) // metros

  // Polígono (GeoJSON serializado)
  coordenadas String?

  color  String?
  activo Boolean @default(true)

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  empresa Empresa                   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  eventos EventoGeocercaLogistica[]

  @@index([empresaId])
}

/// Evento de entrada/salida de una geocerca.
model EventoGeocercaLogistica {
  id            Int                         @id @default(autoincrement())
  empresaId     Int
  geocercaId    Int
  dispositivoId Int?
  vehiculoId    Int?
  tipo          TipoEventoGeocercaLogistica
  lat           Decimal                     @db.Decimal(10, 8)
  lng           Decimal                     @db.Decimal(11, 8)
  timestamp     DateTime                    @default(now())

  geocerca    GeocercaLogistica        @relation(fields: [geocercaId], references: [id], onDelete: Cascade)
  dispositivo DispositivoGpsLogistica? @relation(fields: [dispositivoId], references: [id], onDelete: SetNull)

  @@index([empresaId])
  @@index([geocercaId])
}

model AlmacenLogistica {
  id               Int      @id @default(autoincrement())
  empresaId        Int
  nombre           String
  codigo           String?
  tipo             String   @default("PRINCIPAL") // PRINCIPAL, HUB, CROSSDOCK
  direccion        String
  distrito         String?
  ciudad           String?
  departamento     String?
  lat              Decimal? @db.Decimal(10, 8)
  lng              Decimal? @db.Decimal(11, 8)
  contactoNombre   String?
  contactoTelefono String?
  nroMuelles       Int      @default(1)
  horaApertura     String?
  horaCierre       String?
  activo           Boolean  @default(true)
  creadoEn         DateTime @default(now())
  actualizadoEn    DateTime @updatedAt

  empresa          Empresa             @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  despachosOrigen  DespachoLogistica[] @relation("AlmacenOrigen")
  despachosDestino DespachoLogistica[] @relation("AlmacenDestino")

  @@unique([empresaId, codigo])
  @@index([empresaId])
}

model ZonaEntregaLogistica {
  id              Int      @id @default(autoincrement())
  empresaId       Int
  nombre          String
  codigo          String?
  color           String?  @default("#3B82F6")
  poligonoGeoJSON Json? // Coordenadas del polígono
  costoBase       Decimal  @default(0) @db.Decimal(10, 2)
  costoPorKm      Decimal  @default(0) @db.Decimal(10, 2)
  dificultad      Int      @default(1) // Multiplicador de tiempo
  activa          Boolean  @default(true)
  creadoEn        DateTime @default(now())

  empresa     Empresa                     @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  direcciones DireccionEntregaLogistica[]

  @@index([empresaId])
}

model ClienteLogistica {
  id             Int      @id @default(autoincrement())
  empresaId      Int
  nombre         String
  tipoDocumento  String?
  nroDocumento   String?
  email          String?
  celular        String?
  whatsapp       String?
  scoreConfianza Decimal  @default(100) @db.Decimal(5, 2)
  creadoEn       DateTime @default(now())
  actualizadoEn  DateTime @updatedAt

  empresa     Empresa                     @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  direcciones DireccionEntregaLogistica[]
  pedidos     PedidoLogistica[]

  @@index([empresaId])
  @@index([empresaId, nroDocumento])
}

model DireccionEntregaLogistica {
  id           Int      @id @default(autoincrement())
  empresaId    Int
  clienteId    Int
  zonaId       Int?
  etiqueta     String? // Casa, Trabajo, Almacén
  direccion    String
  distrito     String?
  ciudad       String?
  departamento String?
  lat          Decimal? @db.Decimal(10, 8)
  lng          Decimal? @db.Decimal(11, 8)
  referencia   String?
  notasAcceso  String? // "Dejar en conserjería", "Código puerta 1234"
  esPrincipal  Boolean  @default(false)
  creadoEn     DateTime @default(now())

  empresa Empresa               @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cliente ClienteLogistica      @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  zona    ZonaEntregaLogistica? @relation(fields: [zonaId], references: [id], onDelete: SetNull)
  pedidos PedidoLogistica[]
  paradas ParadaRutaLogistica[]

  @@index([empresaId])
  @@index([clienteId])
}

model PedidoLogistica {
  id              Int                   @id @default(autoincrement())
  empresaId       Int
  codigoTracking  String                @unique
  origen          OrigenPedidoLogistica @default(MANUAL)
  nroOrdenExterna String?

  clienteId          Int
  direccionEntregaId Int

  estado          EstadoPedidoLogistica @default(PENDIENTE)
  fechaSolicitada DateTime?
  ventanaInicio   String? // HH:mm
  ventanaFin      String? // HH:mm
  prioridad       Int                   @default(1) // 1: Baja, 2: Normal, 3: Alta
  esUrgente       Boolean               @default(false)

  // Características de Carga (Sumarizadas de los items)
  pesoTotalKg    Decimal @default(0) @db.Decimal(10, 2)
  volumenTotalM3 Decimal @default(0) @db.Decimal(10, 2)
  nroBultos      Int     @default(1)

  // Requisitos de Entrega
  requiereFirma      Boolean @default(true)
  requiereFoto       Boolean @default(false)
  cobroContraEntrega Decimal @default(0) @db.Decimal(10, 2) // Monto COD

  // Costos Calculados
  costoEnvio Decimal @default(0) @db.Decimal(10, 2)

  notasCliente  String?
  notasInternas String?

  // Integraciones Externas
  externalOrderId   String?
  externalSystem    String?
  externalPayload   Json?
  integrationStatus String?
  webhookStatus     String?
  lastSyncAt        DateTime?

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  empresa          Empresa                   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cliente          ClienteLogistica          @relation(fields: [clienteId], references: [id], onDelete: Restrict)
  direccionEntrega DireccionEntregaLogistica @relation(fields: [direccionEntregaId], references: [id], onDelete: Restrict)

  items              ItemPedidoLogistica[]
  despachosAsignados DespachoPedidoLogistica[]
  pruebasEntrega     PruebaEntregaLogistica[]
  incidencias        IncidenciaPedidoLogistica[]
  historialEstados   HistorialEstadoPedidoLogistica[]

  @@index([empresaId])
  @@index([empresaId, estado])
  @@index([codigoTracking])
}

model ItemPedidoLogistica {
  id                Int      @id @default(autoincrement())
  pedidoId          Int
  sku               String?
  descripcion       String
  cantidad          Int      @default(1)
  pesoUnitarioKg    Decimal? @db.Decimal(10, 2)
  volumenUnitarioM3 Decimal? @db.Decimal(10, 2)
  valorDeclarado    Decimal? @db.Decimal(10, 2)

  pedido PedidoLogistica @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  @@index([pedidoId])
}

model DespachoLogistica {
  id        Int                     @id @default(autoincrement())
  empresaId Int
  codigo    String                  @unique // EJ: DESP-2026-0001
  nombre    String?
  estado    EstadoDespachoLogistica @default(BORRADOR)

  almacenOrigenId  Int
  almacenDestinoId Int?
  conductorId      Int?
  vehiculoId       Int?

  fechaProgramada      DateTime
  horaInicioProgramada String? // HH:mm

  // Métricas Calculadas
  distanciaTotalKm  Decimal? @db.Decimal(10, 2)
  tiempoEstimadoMin Int?
  costoEstimado     Decimal? @db.Decimal(10, 2)

  // Realidad
  horaInicioReal  DateTime?
  horaFinReal     DateTime?
  distanciaRealKm Decimal?  @db.Decimal(10, 2)

  notas         String?
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  empresa        Empresa             @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  almacenOrigen  AlmacenLogistica    @relation("AlmacenOrigen", fields: [almacenOrigenId], references: [id], onDelete: Restrict)
  almacenDestino AlmacenLogistica?   @relation("AlmacenDestino", fields: [almacenDestinoId], references: [id], onDelete: SetNull)
  conductor      ConductorLogistica? @relation(fields: [conductorId], references: [id], onDelete: SetNull)
  vehiculo       VehiculoLogistica?  @relation(fields: [vehiculoId], references: [id], onDelete: SetNull)

  pedidos          DespachoPedidoLogistica[]
  rutaOptimizada   RutaOptimizadaLogistica?
  historialEstados HistorialEstadoDespachoLogistica[]

  @@index([empresaId])
  @@index([empresaId, estado])
  @@index([fechaProgramada])
}

model DespachoPedidoLogistica {
  id             Int       @id @default(autoincrement())
  despachoId     Int
  pedidoId       Int
  ordenSecuencia Int?
  eta            DateTime? // Hora estimada de llegada
  estado         String    @default("PENDIENTE") // PENDIENTE, ENTREGADO, FALLIDO

  despacho DespachoLogistica @relation(fields: [despachoId], references: [id], onDelete: Cascade)
  pedido   PedidoLogistica   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  @@unique([despachoId, pedidoId])
  @@index([despachoId])
  @@index([pedidoId])
}

model RutaOptimizadaLogistica {
  id          Int      @id @default(autoincrement())
  despachoId  Int      @unique
  polyline    String // Google Maps polyline u OSRM
  distanciaKm Decimal  @db.Decimal(10, 2)
  duracionMin Int
  creadoEn    DateTime @default(now())

  despacho DespachoLogistica     @relation(fields: [despachoId], references: [id], onDelete: Cascade)
  paradas  ParadaRutaLogistica[]
}

model ParadaRutaLogistica {
  id          Int                 @id @default(autoincrement())
  rutaId      Int
  secuencia   Int
  tipo        TipoParadaLogistica @default(ENTREGA)
  lat         Decimal             @db.Decimal(10, 8)
  lng         Decimal             @db.Decimal(11, 8)
  direccionId Int?
  conductorId Int? // Quién hizo esta parada (por si cambia el conductor)

  // Realidad
  horaLlegada DateTime?
  horaSalida  DateTime?

  ruta      RutaOptimizadaLogistica    @relation(fields: [rutaId], references: [id], onDelete: Cascade)
  direccion DireccionEntregaLogistica? @relation(fields: [direccionId], references: [id], onDelete: SetNull)
  conductor ConductorLogistica?        @relation(fields: [conductorId], references: [id], onDelete: SetNull)

  @@index([rutaId])
}

model PruebaEntregaLogistica {
  id             Int      @id @default(autoincrement())
  pedidoId       Int
  nombreReceptor String?
  dniReceptor    String?
  parentesco     String?
  firmaUrl       String? // URL en S3
  fotosUrls      String[] // URLs en S3
  montoCobrado   Decimal? @db.Decimal(10, 2)
  metodoPago     String?
  lat            Decimal? @db.Decimal(10, 8)
  lng            Decimal? @db.Decimal(11, 8)
  notas          String?
  creadoEn       DateTime @default(now())

  pedido PedidoLogistica @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  @@index([pedidoId])
}

model IncidenciaPedidoLogistica {
  id              Int                     @id @default(autoincrement())
  pedidoId        Int
  tipo            TipoIncidenciaLogistica
  severidad       String                  @default("MEDIA") // BAJA, MEDIA, ALTA, CRITICA
  descripcion     String
  fotosUrls       String[] // URLs en S3
  lat             Decimal?                @db.Decimal(10, 8)
  lng             Decimal?                @db.Decimal(11, 8)
  resuelta        Boolean                 @default(false)
  notasResolucion String?
  creadoEn        DateTime                @default(now())
  actualizadoEn   DateTime                @updatedAt

  pedido PedidoLogistica @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  @@index([pedidoId])
}

model HistorialEstadoPedidoLogistica {
  id             Int                    @id @default(autoincrement())
  pedidoId       Int
  estadoAnterior EstadoPedidoLogistica?
  estadoNuevo    EstadoPedidoLogistica
  motivo         String?
  notas          String?
  lat            Decimal?               @db.Decimal(10, 8)
  lng            Decimal?               @db.Decimal(11, 8)
  usuarioId      Int?
  creadoEn       DateTime               @default(now())

  pedido  PedidoLogistica @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  usuario Usuario?        @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  @@index([pedidoId])
}

model HistorialEstadoDespachoLogistica {
  id             Int                      @id @default(autoincrement())
  despachoId     Int
  estadoAnterior EstadoDespachoLogistica?
  estadoNuevo    EstadoDespachoLogistica
  motivo         String?
  usuarioId      Int?
  creadoEn       DateTime                 @default(now())

  despacho DespachoLogistica @relation(fields: [despachoId], references: [id], onDelete: Cascade)
  usuario  Usuario?          @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  @@index([despachoId])
}

// ── Integraciones API pública (Logística) ──────────────────────────────────

/// Claves de API para la API pública de Logística. Se guarda SOLO el hash
/// (SHA-256) de la clave, nunca el texto plano. `prefijo` y `ultimosCuatro`
/// permiten identificarla en la UI sin poder reconstruirla.
model ApiKeyLogistica {
  id            Int       @id @default(autoincrement())
  empresaId     Int
  nombre        String?
  entorno       String    @default("live") // "live" | "test"
  prefijo       String // p.ej. "sk_live_a1b2" (display)
  ultimosCuatro String // últimos 4 chars (display)
  hash          String    @unique // SHA-256 de la clave completa
  activo        Boolean   @default(true)
  ultimoUsoEn   DateTime?
  revocadaEn    DateTime?
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([empresaId])
  @@index([hash])
}

/// Endpoints de webhook registrados por una empresa para recibir eventos
/// `order.*`. `secret` es el secreto de firma HMAC (`whsec_…`) devuelto una vez.
model WebhookEndpointLogistica {
  id            Int       @id @default(autoincrement())
  empresaId     Int
  endpointId    String    @unique // id público "we_…"
  url           String
  eventos       String[] // eventos suscritos (order.*)
  secret        String // whsec_… (firma HMAC)
  activo        Boolean   @default(true)
  ultimoEnvioEn DateTime?
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([empresaId])
}
