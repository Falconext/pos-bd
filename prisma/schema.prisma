enum EstadoDespachoLogistica {
  BORRADOR
  PLANIFICADO
  APROBADO
  CARGANDO
  LISTO
  EN_CURSO
  COMPLETADO
  CANCELADO
}

enum TipoIncidenciaLogistica {
  DIRECCION_NO_ENCONTRADA
  CLIENTE_AUSENTE
  CLIENTE_RECHAZO
  PAQUETE_DANADO
  PRODUCTO_EQUIVOCADO
  PEDIDO_INCOMPLETO
