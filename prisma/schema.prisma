  montoFinal         Decimal?
  montoEfectivo      Decimal?   @default(0)
  montoYape          Decimal?   @default(0)
  montoPlin          Decimal?   @default(0)
  montoTransferencia Decimal?   @default(0)
  montoTarjeta       Decimal?   @default(0)
