  pedido        PedidoTienda @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  producto      Producto     @relation(fields: [productoId], references: [id])

  @@index([pedidoId])
  @@index([productoId])
  @@index([comboId])
}

model Combo {
  id                  Int                @id @default(autoincrement())
