enum CategoriaGasto {
  PUBLICIDAD
  SUELDOS
  ENVIOS
  COMISIONES
  ALQUILER
  OTROS
  PERSONALIZADA
}

model GastoOperativo {
  id               Int            @id @default(autoincrement())
  empresaId        Int
  mes              Int
  anio             Int
  fecha            DateTime?
  recurrenteDiario Boolean        @default(false)
  fechaInicio      DateTime?
  fechaFin         DateTime?
  categoria        CategoriaGasto
  etiqueta         String?
  monto            Decimal        @db.Decimal(12, 2)
  descripcion      String?
  creadoEn         DateTime       @default(now())
  actualizadoEn    DateTime       @updatedAt
  empresa          Empresa        @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([empresaId, anio, mes])
  @@index([empresaId, fecha])
  @@index([empresaId, recurrenteDiario, fechaInicio, fechaFin])
  @@index([empresaId, categoria])
}

enum EstadoComision {
  PENDIENTE
  PAGADO
}

enum PlataformaAds {
  META
  TIKTOK
}

enum EstadoCampana {
  ACTIVA
  PAUSADA
}

enum FrecuenciaPresupuesto {
  DIARIO
  SEMANAL
  MENSUAL
  TOTAL
}

model CampanaMarketing {
  id                  Int                   @id @default(autoincrement())
  empresaId           Int
  nombre              String
  plataforma          PlataformaAds
  productoId          Int?
  vendedorId          Int?
  comprobanteId       Int?
  presupuestoDiario   Decimal               @db.Decimal(10, 2) // Guardará el prorrateo diario internamente
  presupuestoOriginal Decimal?              @db.Decimal(10, 2) // Guardará el monto original introducido (ej. 140 semanal)
  tipoPresupuesto     FrecuenciaPresupuesto @default(DIARIO)
  moneda              String                @default("PEN")
  fechaInicio         DateTime
  fechaFin            DateTime?
  esRecurrente        Boolean               @default(false)
  estado              EstadoCampana         @default(ACTIVA)
  creadoEn            DateTime              @default(now())
  actualizadoEn       DateTime              @updatedAt

  empresa     Empresa      @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  producto    Producto?    @relation(fields: [productoId], references: [id], onDelete: SetNull)
  vendedor    Usuario?     @relation(fields: [vendedorId], references: [id], onDelete: SetNull)
  comprobante Comprobante? @relation(fields: [comprobanteId], references: [id], onDelete: SetNull)

  @@index([empresaId, estado])
  @@index([empresaId, productoId])
  @@index([vendedorId])
  @@index([comprobanteId])
}

model ComisionVendedor {
  id            Int            @id @default(autoincrement())
  vendedorId    Int
  comprobanteId Int
  productoId    Int?
  empresaId     Int
  mes           Int
  anio          Int
  cantidad      Decimal        @db.Decimal(12, 4)
  montoComision Decimal        @db.Decimal(12, 2)
  descripcion   String?
  estado        EstadoComision @default(PENDIENTE)
  creadoEn      DateTime       @default(now())
  actualizadoEn DateTime       @updatedAt
  vendedor      Usuario        @relation(fields: [vendedorId], references: [id])
  comprobante   Comprobante    @relation(fields: [comprobanteId], references: [id], onDelete: Cascade)
  empresa       Empresa        @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([vendedorId, mes, anio])
  @@index([empresaId, mes, anio])
  @@index([comprobanteId])
  @@index([vendedorId, estado])
}

// =============================================
// MÓDULO VEHICULAR (Seguridad Electrónica GPS/Alarmas)
// =============================================

model Vehiculo {
  id            Int      @id @default(autoincrement())
  empresaId     Int
  sedeId        Int?
  placa         String
  marca         String
  modelo        String?
  color         String?
  anio          Int?
  kilometraje      Int?
  nivelCombustible String? // LLENO | 3/4 | 1/2 | 1/4 | VACIO
  clienteId     Int?
  observaciones String?
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  empresa       Empresa                @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cliente       Cliente?               @relation(fields: [clienteId], references: [id])
  actas         ActaInspeccion[]
  contratos     ContratoVehicular[]
  contratoItems ContratoVehiculoItem[]

  @@unique([empresaId, placa])
  @@index([empresaId])
  @@index([empresaId, placa])
  @@index([clienteId])
}

model ActaInspeccion {
  id               Int      @id @default(autoincrement())
  vehiculoId       Int
  tipo             String // INGRESO | RETIRO
  km               Int?
  nivelCombustible String? // LLENO | 3/4 | 1/2 | 1/4 | VACIO
  observaciones    String?
  fotos            String[] // URLs en S3
  checklist        Json? // [{ categoria, item, estado, nota }] estado del vehículo al ingreso/retiro
  usuarioId        Int?
  creadoEn         DateTime @default(now())

  vehiculo Vehiculo @relation(fields: [vehiculoId], references: [id], onDelete: Cascade)
  usuario  Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([vehiculoId])
  @@index([vehiculoId, tipo])
}

model ContratoVehicular {
  id            Int      @id @default(autoincrement())
  empresaId     Int
  vehiculoId    Int
  productoId    Int?
  fechaInicio   DateTime
  fechaFin      DateTime
  estado        String   @default("VIGENTE") // VIGENTE | POR_VENCER | VENCIDO | CANCELADO
  montoAnual    Decimal? @db.Decimal(12, 2)
  observaciones String?
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  empresa  Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  vehiculo Vehiculo  @relation(fields: [vehiculoId], references: [id], onDelete: Cascade)
  producto Producto? @relation(fields: [productoId], references: [id])
  unidades ContratoVehiculoItem[]

  @@index([empresaId])
  @@index([empresaId, estado])
  @@index([vehiculoId])
  @@index([fechaFin])
}

// Vehículos incluidos en un contrato (permite contratos multi-vehículo con
// monto individual por unidad). El `vehiculoId` de ContratoVehicular apunta al
// vehículo principal (el primero) y se conserva por compatibilidad; el detalle
// completo de unidades vive aquí.
model ContratoVehiculoItem {
  id         Int      @id @default(autoincrement())
  contratoId Int
  vehiculoId Int
  montoAnual Decimal? @db.Decimal(12, 2)
  creadoEn   DateTime @default(now())

  contrato ContratoVehicular @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  vehiculo Vehiculo          @relation(fields: [vehiculoId], references: [id], onDelete: Cascade)

  @@unique([contratoId, vehiculoId])
  @@index([contratoId])
  @@index([vehiculoId])
}

